# ════════════════════════════════════════════════════════════
#   🎵 THRINO MUSIC BOT  ·  .env.example
#   Copy to .env for local testing.
#   On Render: add each as an Environment Variable.
# ════════════════════════════════════════════════════════════

# From https://my.telegram.org/apps
API_ID=12345678
API_HASH=abcdef1234567890abcdef1234567890

# From @BotFather
BOT_TOKEN=123456789:AABBCCxxxxxxxxxxx

# From running:  python generate_session.py
# Use a secondary Telegram account — NOT your main account
STRING_SESSION=BQxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx...

# Your personal Telegram user ID (from @userinfobot)
OWNER_ID=987654321

# Bot username without @
BOT_USERNAME=ThrinoMusicBot

# Optional support link
SUPPORT=https://t.me/yoursupportgroup

# Path to YouTube cookies file
COOKIES_FILE=cookies.txt
